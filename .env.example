# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# CORS origins allowed for Expo web (comma-separated).
# Use * to allow all origins (development only).
# Production example: https://myapp.example.com,http://localhost:8081
CORS_ORIGIN=*

# ── Firebase ──────────────────────────────────────────────────────────────────
# Found in Firebase console → Project settings → Service accounts
# → Generate new private key → download JSON

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# IMPORTANT: When setting this in Render or other env var UIs, the private key
# contains real newlines. Paste it exactly as shown in the JSON file.
# The app handles the \n → newline conversion automatically.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
# Named database ID — use "(default)" or your custom DB name (e.g. radiovoxecclesiae-db)
FIREBASE_DATABASE_ID=(default)
